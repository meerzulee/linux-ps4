+#define APCIE_REG_CHIPID_1		0x1108
+#define APCIE_REG_CHIPREV		0x110c
+
+/* Number of implemented MSI registers per function */
+static const int subfuncs_per_func[BAIKAL_NUM_FUNCS] = {
+	//4, 4, 4, 4, 31, 2, 2, 4

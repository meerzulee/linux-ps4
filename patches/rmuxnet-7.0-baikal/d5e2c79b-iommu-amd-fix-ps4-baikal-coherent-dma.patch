From d5e2c79bffe4be6a48d34eaca07139c82a629434 Mon Sep 17 00:00:00 2001
From: rmuxnet <armandas.kvietkus@proton.me>
Date: Fri, 1 May 2026 23:37:29 +0200
Subject: [PATCH] iommu/amd: fix PS4 Baikal coherent DMA

---
 drivers/iommu/amd/iommu.c | 24 ++++++++++++++++++++++++
 1 file changed, 24 insertions(+)

diff --git a/drivers/iommu/amd/iommu.c b/drivers/iommu/amd/iommu.c
index 760d5f4623b553..0ea923664beb93 100644
--- a/drivers/iommu/amd/iommu.c
+++ b/drivers/iommu/amd/iommu.c
@@ -3115,6 +3115,19 @@ static bool amd_iommu_is_attach_deferred(struct device *dev)
 	return dev_data->defer_attach;
 }
 
+static bool amd_iommu_ps4_baikal_force_identity(struct device *dev)
+{
+	struct pci_dev *pdev;
+
+	if (!dev_is_pci(dev))
+		return false;
+
+	pdev = to_pci_dev(dev);
+	return pdev->vendor == PCI_VENDOR_ID_SONY &&
+	       pdev->device >= PCI_DEVICE_ID_SONY_BAIKAL_ACPI &&
+	       pdev->device <= PCI_DEVICE_ID_SONY_BAIKAL_XHCI;
+}
+
 static int amd_iommu_def_domain_type(struct device *dev)
 {
 	struct iommu_dev_data *dev_data;
@@ -3127,6 +3140,17 @@ static int amd_iommu_def_domain_type(struct device *dev)
 	if (dev_is_pci(dev) && to_pci_dev(dev)->untrusted)
 		return IOMMU_DOMAIN_DMA;
 
+	/*
+	 * Baikal southbridge functions require low 31-bit coherent DMA very
+	 * early during probe. Keep the whole 00:14.x group in the identity
+	 * domain so those allocations use direct low-memory DMA instead of the
+	 * translated DMA domain that fails on this hardware.
+	 */
+	if (amd_iommu_ps4_baikal_force_identity(dev) &&
+	    !cc_platform_has(CC_ATTR_MEM_ENCRYPT) &&
+	    !amd_iommu_snp_en)
+		return IOMMU_DOMAIN_IDENTITY;
+
 	/*
 	 * Do not identity map IOMMUv2 capable devices when:
 	 *  - memory encryption is active, because some of those devices

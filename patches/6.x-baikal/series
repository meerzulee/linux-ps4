0100-x86-platform/0001-x86-add-ps4-platform-support.patch

# === 0200: PS4 southbridge drivers (Aeolia/Belize/Baikal, ICC, UART, pwrbutton)
0200-ps4-drivers/0001-drivers-ps4-add-aeolia-belize-baikal.patch
0200-ps4-drivers/0002-ps4-bpcie-icc-fix-ioread-iowrite-pointer-types.patch
# Disabled — needs adaptation for 6.x serial8250 (originally caused triple-fault
# but that may have been the broken bootargs; re-test once we have a clean
# baseline). Track in checkpoint/docs/research/2026-05-08-6x-breakthrough.md.
# 0200-ps4-drivers/0003-ps4-bpcie-uart-set-port-type.patch
# Demote UART init failure to a warning so bpcie_probe completes even when
# port.type is unset and serial8250 rejects registration. Without this on
# 6.x, every PS4 child driver defers forever and initramfs can't find the
# rootfs partition. See patch header for the full diagnosis.
0200-ps4-drivers/0004-ps4-bpcie-make-uart-failure-non-fatal.patch
# bpcie_handle_edge_irq runs a per-subfunc demux that's broken in
# shared-vector mode (no IOMMU-IR): no child virqs exist at
# initial_hwirq + i, so the xHCI command-completion MSI gets swallowed
# and every ENABLE_SLOT hits TRB_RING_TIMEOUT. Bypass the demux when
# the hwirq has the 0x1F shared suffix.
0200-ps4-drivers/0005-ps4-bpcie-shared-vector-demux-bypass.patch
# Option A from checkpoint/docs/LEARNINGS.md. Linux 6.2 reworked PCI
# MSI domain lookup; bpcie's per-function dev_set_msi_domain() is no
# longer honoured. Skip the broken per-function domain creation;
# child PCI devices use the kernel's default PCI MSI domain instead.
# Re-enabled after D+revertA test (boot #14) confirmed forcing IR
# does not give bpcie_create_irq_domain an IR parent to inherit from
# either — neither layer of breakage is unwound by intremap=on.
#
# 2026-05-09: DISABLED in favor of Option B (0007), which keeps
# bpcie_create_irq_domains() running and instead modernises bpcie's
# domain to be a 6.x-style MSI parent (with msi_parent_ops +
# IRQ_DOMAIN_FLAG_MSI_PARENT). 0006 + 0007 are mutually exclusive.
# 0200-ps4-drivers/0006-ps4-bpcie-skip-per-function-msi-domain-on-6.x.patch
# Option E (v9, 2026-05-09): marries Option B v7's MSI ROUTING (parent
# flag + msi_parent_ops + AMDVI bus_token) with Option D v8's COMPOSER
# (writes Baikal-magic addr_lo=0xFEE00000 + irq_map[]-derived index
# instead of the real LAPIC vector that the southbridge silently swallows).
# Both halves are necessary — v7 had routing without composer, v8 had
# composer without routing (and v8 was actually a NULL test because of
# this series-file bug — neither patch applied; see option-d-result.md).
0200-ps4-drivers/0007-ps4-bpcie-option-e-routing-plus-baikal-composer.patch
0200-ps4-drivers/0008-ps4-bpcie-southbridge-msi-config.patch
0200-ps4-drivers/0009-ps4-bpcie-revert-composer-default.patch
0200-ps4-drivers/0010-ps4-bpcie-per-subfunc-mask.patch
# v17 ATTEMPT: switched bpcie_irqnum to pci_irq_vector. Result: WORSE.
# pci_irq_vector returns -EINVAL because our per-device MSI domain
# bypasses standard msi_get_virq lookup. Fallback to pdev->irq=0 made
# ICC register at virq 0 instead of virq 3 (the bpcie_msi_init log
# shows virqs 0..31 ARE allocated for bpcie's 32 MSIs). Reverted in v18.
#
# v18: pure diagnostic — dump ICC STATUS register on every timeout AND
# on icc_interrupt entry. Determines if (a) the IRQ ever fires and
# (b) what STATUS says when ICC commands time out.
0200-ps4-drivers/0011-ps4-bpcie-icc-status-diagnostics.patch
# v19: poll STATUS register after each ICC request and run handler manually.
# Workaround for the unidentified MSI delivery failure: HW writes reply +
# sets STATUS bits but icc_interrupt never fires. Fixes ICC commands so
# HDMI/ps4_bridge can come up. MSI delivery itself still needs diagnosis.
0200-ps4-drivers/0012-ps4-bpcie-icc-poll-fallback.patch
# v30: walk msi_desc list to find real virq for ICC (msi_index=3)
# instead of pdev->irq+3 (which was wrong because pdev->irq=0).
# Eliminates "0.227 No irq handler for vector" spam from real IRQ.
0200-ps4-drivers/0013-ps4-bpcie-icc-msi-walk-virq.patch
# DIAGNOSTIC ONLY — keep applied while we confirm Option B works on hw.
# Once we have a clean boot, comment out and rebuild without trace.
# v9 has its own pr_info — disabled to avoid hunk conflict
# 0200-ps4-drivers/9001-DEBUG-bpcie-msi-trace.patch

# === 0300: Liverpool GPU (amdgpu + radeon + amdkfd + drm_bridge)
0300-gpu-liverpool/0001-amdgpu-add-ps4-liverpool-bridge.patch
0300-gpu-liverpool/0002-radeon-add-liverpool-cik-support.patch
0300-gpu-liverpool/0003-amdkfd-cik-ps4-quirks.patch
0300-gpu-liverpool/0004-drm-bridge-and-pciids.patch
0300-gpu-liverpool/0005-amdgpu-require-msi-for-liverpool.patch
# v20: PS4 internal DP link goes to MN864729/MN86471A bridge chip which
# handles training itself; kernel-side dp_link_train fails clock recovery
# 5x and bails out before bridge_enable runs. Skip DP train for
# CHIP_LIVERPOOL/GLADIUS so bridge_pre_enable + bridge_enable can run.
0300-gpu-liverpool/0006-amdgpu-skip-dp-link-train-liverpool.patch
# v21: PS4 dce_v8 uses legacy non-atomic encoder helpers, so bridge chain
# pre_enable/enable never fires from the modeset path. Force-call them
# from ps4_bridge_register at attach time with hardcoded 1080p60 VIC.
0300-gpu-liverpool/0007-amdgpu-force-ps4-bridge-init-at-attach.patch
# v22: DRM atomic does call ps4_bridge_mode_set + bridge_enable (when
# lightdm starts) but drm_match_cea_mode returns 0 for the mode passed,
# so mn_bridge->mode=0 and bridge_enable bails "mode not available".
# Default to VIC 16 (1080p60) when CEA match fails. Also widen
# mode_valid to accept 1920x1080 / 1280x720 even without exact CEA match.
0300-gpu-liverpool/0008-amdgpu-ps4-bridge-default-vic-16.patch
# v23: verbose diagnostics on bridge_pre_enable, bridge_enable, detect.
# Promotes DRM_DEBUG_KMS to pr_info; logs cq_exec return values.
# Pure diagnostic, no behavior change.
0300-gpu-liverpool/0009-amdgpu-ps4-bridge-verbose-diagnostics.patch
# v24: bridge programs for VIC 16 (1080p) but DRM passes 1400x1050 to GPU
# encoder -> mismatch -> blank. Add mode_fixup that rewrites adjusted_mode
# with canonical 1920x1080@60Hz so GPU+bridge agree.
0300-gpu-liverpool/0010-amdgpu-ps4-bridge-force-1080p-mode-fixup.patch
# v25: Remove 1080p120 mode (community guide notes 120Hz causes
# "unsupported resolution"/no signal). Mark 1080p60 as PREFERRED.
0300-gpu-liverpool/0011-amdgpu-ps4-bridge-remove-1080p120-mode.patch
# v28/v29: ATOM BIOS AdjustDisplayPll returns 0 on PS4 (known ATOM init
# issues). adjusted_clock=0 -> dce_v8_0_crtc_mode_set returns -EINVAL.
# Fall back to adjusted_mode->clock when ATOM returns nothing.  In v28
# we ALSO no-op'd the bridge mode_fixup overwrite (v27); v29 reverted
# that because the bridge needs adjusted_mode timing to match VIC 16
# (mode_1080p struct) for HDMI signal to lock - otherwise backlight
# stops. So: keep v24's mode_fixup overwrite + v28's clock fallback.
0300-gpu-liverpool/0013-amdgpu-dce-v8-fallback-adjusted-clock.patch
# v31: bridge_disable mutes the bridge before GPU TX reprograms; bridge then
# fails to re-lock to the new signal -> backlight goes off after first
# successful mode_set. Remove .disable so bridge stays running through
# GPU reprogramming.
0300-gpu-liverpool/0014-amdgpu-ps4-bridge-no-disable.patch
# v32: 500ms msleep at start of bridge_enable so GPU's DP TX has time
# to stabilize before the MN864729 tries to lock. Without the delay, the
# cq_wait_set steps for DP lane status silently no-op on unstable signal.
0300-gpu-liverpool/0015-amdgpu-ps4-bridge-msleep-settle.patch


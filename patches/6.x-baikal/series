# 0800-usb-aeolia/0003-xhci-aeolia-fix-baikal-hcd-setup.patch
# 0800-usb-aeolia/0004-xhci-aeolia-fix-baikal-xhci-setup.patch
# Hand-ported from rmuxnet/ps4-linux-12xx f6cf0e0d. Adds two msleep()s
# in xhci_aeolia_probe so Baikal xHCI gets settle time before
# command-queue traffic. Targets the `Command Aborted` enable-slot
# failure that prevents USB enumeration.
0800-usb-aeolia/0005-xhci-aeolia-baikal-settle-timing.patch
# Hand-port from rmuxnet 8f2f907b. Always route xhci-aeolia IRQ through
# apcie_assign_irqs() (which delegates to bpcie_assign_irqs on Baikal).
# The previous Baikal-specific pci_alloc_irq_vectors() path bypassed the
# bpcie MSI domain, so command-completion IRQs were never delivered and
# every ENABLE_SLOT hit TRB_RING_TIMEOUT → Command Aborted.
0800-usb-aeolia/0006-xhci-aeolia-baikal-irq-via-apcie-assign.patch
# Hand-port from rmuxnet ps4-baikal-7.0-port HEAD xhci_aeolia_setup. Adds
# imod_interval=40000 (10ms moderation) + caps validation + retry on
# -ENOMEM when protocol caps not yet readable. Targets the residual
# 5-second TRB_RING_TIMEOUT / Command Aborted on Baikal even after
# 0005 (settle delays) + 0006 (IRQ via apcie).
0800-usb-aeolia/0007-xhci-aeolia-baikal-setup-imod-and-retry.patch


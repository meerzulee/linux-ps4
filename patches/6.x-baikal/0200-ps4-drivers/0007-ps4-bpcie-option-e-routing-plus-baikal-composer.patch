From: PS4 Linux Baikal Port <noreply@ps4-linux>
Subject: [PATCH] drivers/ps4: Option E v9 - MSI parent routing + Baikal-magic compose_msg

Marries Option B v7's MSI ROUTING (parent flag + msi_parent_ops + AMDVI
bus_token) with Option D v8's COMPOSER (writes Baikal-magic addr_lo=
0xFEE00000 + irq_map[]-derived index instead of the real LAPIC vector
that the southbridge silently swallows).  Both halves are necessary:
v3-v7 had routing without composer; v8 was a NULL test (patch never
applied due to series-file mismatch).

Verified that x86_init_dev_msi_info (called via msi_parent_init_dev_msi_info
in our bpcie_init_dev_msi_info) does NOT touch info->chip->irq_compose_msi_msg,
so the new composer survives the per-device MSI domain inheritance chain.

Changes vs vanilla bpcie (post-0006 baseline):
  - aeolia-baikal.h: int irq_map[100] in struct abpcie_dev
  - ps4-bpcie.c:
    - bpcie_irq_msi_compose_msg writing addr_lo=0xFEE00000 + index
    - irq_chip.irq_compose_msi_msg = bpcie_irq_msi_compose_msg
    - bpcie_msi_init populates next-free irq_map slot
    - bpcie_probe memsets irq_map to all -1
    - All Option B v7 scaffolding restored: IRQ_DOMAIN_FLAG_MSI_PARENT,
      msi_parent_ops, init_dev_msi_info, AMDVI bus_token override,
      dev_set_msi_domain install.
---
--- a/drivers/ps4/aeolia-baikal.h
+++ b/drivers/ps4/aeolia-baikal.h
@@ -64,6 +64,9 @@
 	int nvec;
 	int serial_line[2];
 	struct abpcie_icc_dev icc;
+
+	/* Option E: virq → Baikal-internal subfunction-index lookup. */
+	int irq_map[100];
 };
 
 #define BUF_FULL 0x7f0
--- a/drivers/ps4/ps4-bpcie.c
+++ b/drivers/ps4/ps4-bpcie.c
@@ -62,6 +62,40 @@
 	pci_msi_domain_write_msg(data, msg);
 }
 
+/*
+ * Option E (v9) — Baikal-magic composer.  See checkpoint/docs/research/
+ * 2026-05-09-option-d-thesis.md.
+ */
+static void bpcie_irq_msi_compose_msg(struct irq_data *data,
+				      struct msi_msg *msg)
+{
+	struct bpcie_dev *sc = data->chip_data;
+	struct irq_cfg *cfg __maybe_unused = irqd_cfg(data);
+	int i;
+
+	if (!cfg)
+		pr_err("ps4-bpcie: irq_cfg is NULL in %s\n", __func__);
+
+	memset(msg, 0, sizeof(*msg));
+	msg->address_hi = X86_MSI_BASE_ADDRESS_HIGH;
+	msg->address_lo = 0xfee00000; /* Baikal-magic sentinel, NOT a LAPIC dest */
+
+	msg->data = data->irq - 1;
+	if (sc) {
+		for (i = 0; i < ARRAY_SIZE(sc->irq_map); i++) {
+			if (sc->irq_map[i] == data->irq) {
+				msg->data = i;
+				break;
+			}
+		}
+		pr_info("bpcie_irq_msi_compose_msg: irq=%d index=%u sc=%p\n",
+			data->irq, msg->data, sc);
+	} else {
+		pr_warn("bpcie_irq_msi_compose_msg: sc is NULL irq=%d (fallback data=%u)\n",
+			data->irq, msg->data);
+	}
+}
+
 static void bpcie_msi_unmask(struct irq_data *data)
 {
 	pci_msi_unmask_irq(data);
@@ -198,7 +232,7 @@
 	.irq_ack = irq_chip_ack_parent,
 	.irq_set_affinity = msi_domain_set_affinity,
 	.irq_retrigger = irq_chip_retrigger_hierarchy,
-	.irq_compose_msi_msg = x86_vector_msi_compose_msg,  // this seems kinda wrong
+	.irq_compose_msi_msg = bpcie_irq_msi_compose_msg, /* Option E v9 — Baikal-magic */
 	.irq_write_msi_msg = bpcie_msi_write_msg,
 	.flags = IRQCHIP_SKIP_SET_WAKE,
 };
@@ -286,13 +320,26 @@
 			 struct msi_domain_info *info, unsigned int virq,
 			 irq_hw_number_t hwirq, msi_alloc_info_t *arg)
 {
-	struct irq_data *data;
-	pr_devel("bpcie_msi_init(%p, %p, %d, 0x%lx, %p)\n", domain, info, virq, hwirq, arg);
+	struct bpcie_dev *sc = info->chip_data;
+	int i;
+
+	pr_info("bpcie_msi_init: virq=%d hwirq=0x%lx domain=%p info=%p sc=%p\n",
+		virq, hwirq, domain, info, sc);
 
-	data = irq_domain_get_irq_data(domain, virq);
 	irq_domain_set_info(domain, virq, hwirq, info->chip, info->chip_data,
-			bpcie_handle_edge_irq/*handle_edge_irq*/, NULL, "edge");
-	//bpcie_msi_calc_mask(data);
+			bpcie_handle_edge_irq, NULL, "edge");
+
+	/* Option E: virq → next-free irq_map slot, used by composer. */
+	if (sc) {
+		for (i = 0; i < ARRAY_SIZE(sc->irq_map); i++) {
+			if (sc->irq_map[i] == -1) {
+				sc->irq_map[i] = virq;
+				pr_info("bpcie_msi_init: registered virq=%d irq_map[%d]\n",
+					virq, i);
+				break;
+			}
+		}
+	}
 	return 0;
 }
 
@@ -305,7 +352,12 @@
 static int bpcie_msi_prepare(struct irq_domain *domain, struct device *dev,
 				  int nvec, msi_alloc_info_t *arg)
 {
-	memset(arg, 0, sizeof(*arg));
+	/* v7: BaikalLove fix — old code did memset(arg, 0) which wiped
+	 * the type field x86 needs to allocate a PCI MSI vector.  Without
+	 * this, x86_vector_alloc_irqs falls back to spurious vectors.
+	 * Pattern lifted from arch/x86/kernel/apic/msi.c::pci_msi_prepare. */
+	init_irq_alloc_info(arg, NULL);
+	arg->type = X86_IRQ_ALLOC_TYPE_PCI_MSI;
 	return 0;
 }
 
@@ -318,10 +370,11 @@
 };
 
 static struct msi_domain_info bpcie_msi_domain_info = {
-	.flags		= MSI_FLAG_USE_DEF_DOM_OPS | MSI_FLAG_USE_DEF_CHIP_OPS, //maybe also | MSI_FLAG_ACTIVATE_EARLY
+	.flags		= MSI_FLAG_USE_DEF_DOM_OPS | MSI_FLAG_USE_DEF_CHIP_OPS,
 	.ops		= &bpcie_msi_domain_ops,
 	.chip		= &bpcie_msi_controller,
 	.handler	= bpcie_handle_edge_irq/*handle_edge_irq*/,
+	.handler_name	= "edge", /* v7: BaikalLove note — "Seems important now" in 6.x */
 };
 
 static void bpcie_msi_domain_set_desc(msi_alloc_info_t *arg,
@@ -349,6 +402,68 @@
 	#endif
 }
 
+/*
+ * Option B v6 (Linux 6.2+ per-device MSI rework, Baikal demuxer-aware):
+ *
+ * v3-v5 used the kernel-provided helper msi_parent_init_dev_msi_info()
+ * directly, which delegates to x86_vector_domain's init_dev_msi_info.
+ * That setup correctly programmed each child's MSI cap with a real vector
+ * (verified in UART), but installed the standard handle_edge_irq at each
+ * leaf — which is wrong for Baikal hardware.
+ *
+ * Baikal hardware demuxes ALL subfunc MSIs through function 4 (Glue):
+ * when ANY subfunction wants to interrupt, hardware writes BPCIE_ACK_WRITE
+ * on Glue and Glue's MSI fires.  bpcie_handle_edge_irq is what reads
+ * BPCIE_ACK_READ to identify which subfunc fired and dispatch its
+ * handler.  Without our demuxer in the leaf handler chain, function 4's
+ * MSI fires → kernel runs handle_edge_irq → only ONE subfunc handler
+ * gets to run → all 31 other subfuncs are silent.
+ *
+ * Symptom in v5 (Boot #18, 2026-05-09): bpcie_handle_edge_irq fires
+ * 0 times across the whole boot.  Every driver under bpcie (xhci, ahci,
+ * sdhci, even bpcie's own ICC pwrbutton init) times out on its command
+ * completion interrupt, despite MSI caps being correctly programmed.
+ *
+ * Fix: after letting msi_parent_init_dev_msi_info do its job, override
+ * info->handler back to bpcie_handle_edge_irq and set info->chip_data
+ * to the bpcie_dev so the demuxer can glue_read32() the ACK register.
+ */
+static struct bpcie_dev *bpcie_dev_for_child_pdev(struct pci_dev *child)
+{
+	unsigned int sc_devfn = (child->devfn & ~7) | BAIKAL_FUNC_ID_PCIE;
+	struct pci_dev *sc_dev = pci_get_slot(child->bus, sc_devfn);
+	struct bpcie_dev *sc = sc_dev ? pci_get_drvdata(sc_dev) : NULL;
+	if (sc_dev)
+		pci_dev_put(sc_dev);
+	return sc;
+}
+
+static bool bpcie_init_dev_msi_info(struct device *dev,
+				     struct irq_domain *domain,
+				     struct irq_domain *real_parent,
+				     struct msi_domain_info *info)
+{
+	if (!msi_parent_init_dev_msi_info(dev, domain, real_parent, info))
+		return false;
+
+	/* Re-install bpcie's demuxer at the leaf level — Baikal hardware
+	 * routes all subfunc MSIs through function 4, so bpcie_handle_edge_irq
+	 * must run to read BPCIE_ACK_READ and dispatch to the right subfunc. */
+	info->handler = bpcie_handle_edge_irq;
+	info->handler_name = "bpcie-edge";
+	info->chip_data = bpcie_dev_for_child_pdev(to_pci_dev(dev));
+	pr_info("bpcie_init_dev_msi_info: dev=%s installed bpcie demuxer (sc=%p)\n",
+		dev_name(dev), info->chip_data);
+	return true;
+}
+
+static const struct msi_parent_ops bpcie_msi_parent_ops = {
+	.supported_flags	= MSI_GENERIC_FLAGS_MASK | MSI_FLAG_PCI_MSIX |
+				  MSI_FLAG_MULTI_PCI_MSI,
+	.init_dev_msi_info	= bpcie_init_dev_msi_info,
+	.prefix			= "bpcie-",
+};
+
 struct irq_domain *bpcie_create_irq_domain(struct bpcie_dev *sc, struct pci_dev *pdev)//similar to hpet_create_irq_domain
 {
 	struct irq_domain *domain, *parent;
@@ -387,12 +502,44 @@
 		bpcie_msi_controller.name = "IR-Baikal-MSI";
 	}
 
-	domain = msi_create_irq_domain(fn, &bpcie_msi_domain_info, parent);
+	/* v7: BaikalLove fix — use pci_msi_create_irq_domain instead of
+	 * msi_create_irq_domain.  The PCI variant adds MSI_FLAG_ACTIVATE_EARLY
+	 * (re-composes msg with real vector at alloc time, not request_irq
+	 * time), MSI_FLAG_FREE_MSI_DESCS, MSI_FLAG_DEV_SYSFS,
+	 * IRQCHIP_ONESHOT_SAFE, and runs pci_msi_domain_update_dom_ops/
+	 * chip_ops to set proper PCI MSI defaults.  Sets bus_token to
+	 * DOMAIN_BUS_PCI_MSI (we override below to AMDVI for x86 vector
+	 * gate compat — see irq_domain_update_bus_token call). */
+	domain = pci_msi_create_irq_domain(fn, &bpcie_msi_domain_info, parent);
 	if (!domain) {
 		irq_domain_free_fwnode(fn);
 		pr_warn("Failed to initialize Baikal-MSI irqdomain.\n");
+		return NULL;
 	}
 
+	/*
+	 * Option B: mark this domain as a 6.x MSI parent so that the kernel's
+	 * pci_msi_setup_msi_irqs path will walk it instead of falling through
+	 * to the default x86 vector domain (which would deliver MSIs as
+	 * APIC_SPURIOUS_VECTOR (0xef) on the LAPIC and lose them).
+	 */
+	domain->flags |= IRQ_DOMAIN_FLAG_MSI_PARENT;
+	domain->msi_parent_ops = &bpcie_msi_parent_ops;
+	/*
+	 * Option B v4: x86's x86_init_dev_msi_info() (the kernel helper we
+	 * delegate to via msi_parent_init_dev_msi_info) gates on
+	 * real_parent->bus_token: only DOMAIN_BUS_ANY (which requires
+	 * domain == real_parent — for x86_vector itself), DOMAIN_BUS_DMAR,
+	 * and DOMAIN_BUS_AMDVI are accepted; everything else WARN()s and
+	 * returns false (causing all child MSI allocs to fail with
+	 * -EPROBE_DEFER).  Pretend to be AMDVI — semantically the closest
+	 * (AMD platform, intermediate MSI-routing parent) and architecturally
+	 * the role bpcie plays between x86_vector and Baikal child PCI devs.
+	 */
+	irq_domain_update_bus_token(domain, DOMAIN_BUS_AMDVI);
+	pr_info("bpcie_create_irq_domain: marked %s as MSI parent (flags=0x%x bus_token=AMDVI)\n",
+		domain->name, domain->flags);
+
 	return domain;
 }
 
@@ -473,6 +620,16 @@
 		if (bpcie_pdev) {
 			struct irq_domain * domain = bpcie_create_irq_domain(sc, bpcie_pdev);
 			if (func == BAIKAL_FUNC_ID_PCIE) sc->irqdomain = domain;
+			/*
+			 * Option B (continued): install the domain on this pdev so that
+			 * the 6.x PCI MSI core (pci_msi_setup_msi_irqs →
+			 * dev_get_msi_domain) actually finds it. Without this the
+			 * domain is marked MSI parent but unreachable; the kernel
+			 * falls back to the default x86 vector domain and MSIs are
+			 * delivered as APIC_SPURIOUS_VECTOR (0xef).
+			 */
+			if (domain)
+				dev_set_msi_domain(&bpcie_pdev->dev, domain);
 			pci_dev_put(bpcie_pdev);
 		} else
 			sc_err("cannot find bpcie func %d device", func);
@@ -587,6 +744,7 @@
 		goto disable_dev;
 	}
 	sc->pdev = dev;
+	memset(sc->irq_map, -1, sizeof(sc->irq_map)); /* Option E */
 	pci_set_drvdata(dev, sc);
 
 	// eMMC ... unused?

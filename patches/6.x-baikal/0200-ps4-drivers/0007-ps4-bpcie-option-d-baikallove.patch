+/*
+ * Option D (2026-05-09): legacy MSI domain + Baikal-magic compose_msg.
+ *
+ * v1-v7 chased Linux 6.2's per-device MSI parent rework: marked the bpcie
+ * domain as IRQ_DOMAIN_FLAG_MSI_PARENT, supplied msi_parent_ops::init_dev_msi_info,
+ * delegated to x86_vector via msi_parent_init_dev_msi_info, and let the
+ * kernel write a real LAPIC vector into each child's MSI cap.  Across all
+ * seven attempts, bpcie_handle_edge_irq fired 0 times — because the PS4
+ * Baikal southbridge does not pass child MSI writes through to the LAPIC
+ * at all.  It captures the HT transaction at addr=0xFEE00000, decodes the
+ * data field as an internal subfunction-index, and routes that into its
+ * own ACK_READ register, then fires one real MSI on bpcie's (function 4
+ * / Glue) vector pool.
+ *
+ * Writing addr_lo=0xFEE02000 data=0x20 (a real LAPIC vector targeting
+ * APIC ID 2) made no sense to that hardware path — silently swallowed.
+ *
+ * Faithful port of feeRnt's x_exp__6.15.4-BaikalLove approach: keep the
+ * legacy non-MSI-parent domain, override .irq_compose_msi_msg with our own
+ * composer that writes the Baikal-magic tuple, and track virq → subfunc
+ * index in sc->irq_map[].
+ */
 struct irq_domain *bpcie_create_irq_domain(struct bpcie_dev *sc, struct pci_dev *pdev)//similar to hpet_create_irq_domain
 {
 	struct irq_domain *domain, *parent;
@@ -409,12 +497,21 @@
 		bpcie_msi_controller.name = "IR-Baikal-MSI";
 	}
 
-	domain = msi_create_irq_domain(fn, &bpcie_msi_domain_info, parent);
+	/* Option D: keep pci_msi_create_irq_domain (sets MSI_FLAG_ACTIVATE_EARLY,
+	 * MSI_FLAG_FREE_MSI_DESCS, MSI_FLAG_DEV_SYSFS, IRQCHIP_ONESHOT_SAFE,
+	 * runs pci_msi_domain_update_dom_ops/chip_ops, bus_token=PCI_MSI).
+	 * But do NOT mark as IRQ_DOMAIN_FLAG_MSI_PARENT — child PCI devs should
+	 * allocate IRQs directly from this legacy 2-level (bpcie → x86_vector)
+	 * domain hierarchy, with our compose_msg writing the Baikal-magic tuple. */
+	domain = pci_msi_create_irq_domain(fn, &bpcie_msi_domain_info, parent);
 	if (!domain) {
 		irq_domain_free_fwnode(fn);
 		pr_warn("Failed to initialize Baikal-MSI irqdomain.\n");
+		return NULL;
 	}
-
+	pr_info("bpcie_create_irq_domain: %s ready (flags=0x%x bus_token=%d) parent=%s\n",
+		domain->name, domain->flags, domain->bus_token,
+		parent->name ? parent->name : "(unnamed)");
 	return domain;
 }
 
@@ -495,6 +592,16 @@
 		if (bpcie_pdev) {
 			struct irq_domain * domain = bpcie_create_irq_domain(sc, bpcie_pdev);
 			if (func == BAIKAL_FUNC_ID_PCIE) sc->irqdomain = domain;
+			/*
+			 * Option B (continued): install the domain on this pdev so that
+			 * the 6.x PCI MSI core (pci_msi_setup_msi_irqs →
+			 * dev_get_msi_domain) actually finds it. Without this the
+			 * domain is marked MSI parent but unreachable; the kernel
+			 * falls back to the default x86 vector domain and MSIs are
+			 * delivered as APIC_SPURIOUS_VECTOR (0xef).
+			 */
+			if (domain)
+				dev_set_msi_domain(&bpcie_pdev->dev, domain);
 			pci_dev_put(bpcie_pdev);
 		} else
 			sc_err("cannot find bpcie func %d device", func);
@@ -609,6 +716,7 @@
 		goto disable_dev;
 	}
 	sc->pdev = dev;
+	memset(sc->irq_map, -1, sizeof(sc->irq_map)); /* Option D */
 	pci_set_drvdata(dev, sc);
 

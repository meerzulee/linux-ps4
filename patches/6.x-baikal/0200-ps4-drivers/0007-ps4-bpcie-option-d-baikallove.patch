From: PS4 Linux Baikal Port <noreply@ps4-linux>
Subject: [PATCH] drivers/ps4: Option D - bpcie legacy MSI domain + Baikal-magic compose_msg

PS4 Baikal southbridge does NOT pass child MSI writes through to the LAPIC.
It captures HT transactions to addr=0xFEE00000, decodes the data field as
an internal subfunction-index, accumulates into BPCIE_ACK_READ, and fires
ONE real MSI on bpcie's (function-4 Glue) vector pool — which the kernel
dispatches to bpcie_handle_edge_irq, the demuxer.

v1-v7 (Option B) chased Linux 6.2's per-device MSI-parent rework: marked
the bpcie domain as IRQ_DOMAIN_FLAG_MSI_PARENT, supplied msi_parent_ops::
init_dev_msi_info, delegated to x86_vector via msi_parent_init_dev_msi_info,
and let the kernel write a real LAPIC vector into each child's MSI cap.
Across all seven attempts, bpcie_handle_edge_irq fired 0 times — because
the southbridge silently swallowed every child MSI (writing addr_lo=fee02000
data=0x20 makes no sense to that hardware path; it expects 0xFEE00000 +
subfunc-index).

Option D (this patch) faithfully ports feeRnt's x_exp__6.15.4-BaikalLove
approach:

  1. Add int irq_map[100] to struct abpcie_dev, init to -1 in probe.
  2. New bpcie_irq_msi_compose_msg writing addr_lo=0xFEE00000,
     data=irq_map[]-derived-index.
  3. bpcie_msi_init populates irq_map[next_free] = virq.
  4. irq_chip.irq_compose_msi_msg switches to our composer.
  5. Drop IRQ_DOMAIN_FLAG_MSI_PARENT, msi_parent_ops, init_dev_msi_info,
     and the AMDVI bus_token override — child PCI devs allocate IRQs
     directly from this legacy 2-level (bpcie → x86_vector) hierarchy.
  6. Keep dev_set_msi_domain install (BaikalLove keeps it).
  7. Keep pci_msi_create_irq_domain (BaikalLove uses it).

References:
  - feeRnt/ps4-linux-12xx branch x_exp__6.15.4-BaikalLove
    (research/upstream-bpcie-survey/feeRnt_x_exp__6.15.4-BaikalLove.c)
  - checkpoint/docs/research/2026-05-09-option-d-thesis.md
---
--- a/drivers/ps4/aeolia-baikal.h
+++ b/drivers/ps4/aeolia-baikal.h
@@ -64,6 +64,12 @@
 	int nvec;
 	int serial_line[2];
 	struct abpcie_icc_dev icc;
+
+	/* Option D: virq → Baikal-internal subfunction-index lookup table.
+	 * Populated in bpcie_msi_init at MSI alloc time, read in
+	 * bpcie_irq_msi_compose_msg to write the index into each child's
+	 * MSI cap as the data field.  -1 means slot is free. */
+	int irq_map[100];
 };
 
 #define BUF_FULL 0x7f0
--- a/drivers/ps4/ps4-bpcie.c
+++ b/drivers/ps4/ps4-bpcie.c
@@ -80,6 +80,51 @@
 	}
 }
 
+/*
+ * Option D: Baikal southbridge does MSI virtualization.  Child PCI funcs do
+ * not deliver MSI directly to the LAPIC; instead they write a Baikal-magic
+ * tuple to an HT transaction (addr=0xFEE00000, data=<subfunc_index>) and the
+ * southbridge captures that, accumulates the bit into BPCIE_ACK_READ, and
+ * fires ONE real MSI on bpcie's own (function-4 Glue) vector pool — which
+ * the kernel then dispatches to bpcie_handle_edge_irq, the demuxer.
+ *
+ * v1-v7 used x86_vector_msi_compose_msg, which writes a real LAPIC vector.
+ * The southbridge can't decode that and silently drops the IRQ.
+ *
+ * Faithful port of feeRnt's bpcie_irq_msi_compose_msg from
+ * x_exp__6.15.4-BaikalLove.  msg->data is an irq_map[] index, populated by
+ * bpcie_msi_init at alloc time.  msg->address_lo is a fixed sentinel.
+ */
+static void bpcie_irq_msi_compose_msg(struct irq_data *data,
+				      struct msi_msg *msg)
+{
+	struct bpcie_dev *sc = data->chip_data;
+	struct irq_cfg *cfg __maybe_unused = irqd_cfg(data);
+	int i;
+
+	if (!cfg)
+		pr_err("ps4-bpcie: irq_cfg is NULL in %s\n", __func__);
+
+	memset(msg, 0, sizeof(*msg));
+	msg->address_hi = X86_MSI_BASE_ADDRESS_HIGH;
+	msg->address_lo = 0xfee00000; /* Baikal-magic sentinel, NOT a LAPIC dest */
+
+	msg->data = data->irq - 1;
+	if (sc) {
+		for (i = 0; i < ARRAY_SIZE(sc->irq_map); i++) {
+			if (sc->irq_map[i] == data->irq) {
+				msg->data = i;
+				break;
+			}
+		}
+		pr_info("bpcie_irq_msi_compose_msg: irq=%d → index=%u sc=%p\n",
+			data->irq, msg->data, sc);
+	} else {
+		pr_warn("bpcie_irq_msi_compose_msg: sc is NULL for irq=%d (fallback data=%u)\n",
+			data->irq, msg->data);
+	}
+}
+
 static void bpcie_msi_unmask(struct irq_data *data)
 {
 	pci_msi_unmask_irq(data);
@@ -216,7 +261,7 @@
 	.irq_ack = irq_chip_ack_parent,
 	.irq_set_affinity = msi_domain_set_affinity,
 	.irq_retrigger = irq_chip_retrigger_hierarchy,
-	.irq_compose_msi_msg = x86_vector_msi_compose_msg,  // this seems kinda wrong
+	.irq_compose_msi_msg = bpcie_irq_msi_compose_msg, /* Option D — Baikal-magic */
 	.irq_write_msi_msg = bpcie_msi_write_msg,
 	.flags = IRQCHIP_SKIP_SET_WAKE,
 };
@@ -308,13 +353,28 @@
 			 struct msi_domain_info *info, unsigned int virq,
 			 irq_hw_number_t hwirq, msi_alloc_info_t *arg)
 {
-	struct irq_data *data;
-	pr_info("bpcie_msi_init: virq=%d hwirq=0x%lx domain=%p info=%p\n", virq, hwirq, domain, info);
+	struct bpcie_dev *sc = info->chip_data;
+	int i;
+
+	pr_info("bpcie_msi_init: virq=%d hwirq=0x%lx domain=%p info=%p sc=%p\n",
+		virq, hwirq, domain, info, sc);
 
-	data = irq_domain_get_irq_data(domain, virq);
 	irq_domain_set_info(domain, virq, hwirq, info->chip, info->chip_data,
-			bpcie_handle_edge_irq/*handle_edge_irq*/, NULL, "edge");
-	//bpcie_msi_calc_mask(data);
+			bpcie_handle_edge_irq, NULL, "edge");
+
+	/* Option D: register virq → next-free index in sc->irq_map.
+	 * bpcie_irq_msi_compose_msg uses this to write the index as
+	 * msg->data into the device's MSI cap. */
+	if (sc) {
+		for (i = 0; i < ARRAY_SIZE(sc->irq_map); i++) {
+			if (sc->irq_map[i] == -1) {
+				sc->irq_map[i] = virq;
+				pr_info("bpcie_msi_init: registered virq=%d at irq_map[%d]\n",
+					virq, i);
+				break;
+			}
+		}
+	}
 	return 0;
 }
 
@@ -327,7 +387,12 @@
 static int bpcie_msi_prepare(struct irq_domain *domain, struct device *dev,
 				  int nvec, msi_alloc_info_t *arg)
 {
-	memset(arg, 0, sizeof(*arg));
+	/* v7: BaikalLove fix — old code did memset(arg, 0) which wiped
+	 * the type field x86 needs to allocate a PCI MSI vector.  Without
+	 * this, x86_vector_alloc_irqs falls back to spurious vectors.
+	 * Pattern lifted from arch/x86/kernel/apic/msi.c::pci_msi_prepare. */
+	init_irq_alloc_info(arg, NULL);
+	arg->type = X86_IRQ_ALLOC_TYPE_PCI_MSI;
 	return 0;
 }
 
@@ -340,10 +405,11 @@
 };
 

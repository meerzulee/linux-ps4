+// SPDX-License-Identifier: GPL-2.0
+/*
+ * PS4 console power-off via ICC mailbox.
+ *
+ * Without this driver, `systemctl poweroff` halts Linux but the PS4
+ * stays at standby (white LED on, fans on) until the EMC watchdog
+ * times out ~30 s later and cuts power ungracefully. Sony's Orbis
+ * kernel runs an ICC mailbox command at shutdown_final time to ask
+ * the EMC to cut console rails; we transliterate the same command
+ * into a Linux reboot_notifier so the EMC sees it during a normal
+ * Linux poweroff.
+ *
+ * Why reboot_notifier and not pm_power_off
+ * ----------------------------------------
+ * Our first iteration (v72b) hooked pm_power_off. That fires at the
+ * very end of kernel_power_off(), AFTER kernel_shutdown_prepare has
+ * already invoked every device's .shutdown callback — which includes
+ * bpcie/apcie tearing down their PCI state and unmapping the ICC
+ * mailbox. By the time our handler ran, apcie_icc_cmd had no live
+ * channel to send through; the call returned without error (or with
+ * a silent error after UART was also gone) and Linux just halted.
+ * Net effect: console stayed at standby, identical to having no hook
+ * at all. See UART log 2026-05-11_1532-v72b-poweroff-retry.log.
+ *
+ * reboot_notifier_list, by contrast, fires *before* device shutdown
+ * — early in __do_sys_reboot() right after the syscall validates
+ * the magic numbers. At that point bpcie_icc_cmd / apcie_icc_cmd are
+ * still fully functional. We filter on action==SYS_POWER_OFF so the
+ * notifier is a no-op for SYS_HALT / SYS_RESTART (admin halted to
+ * standby intentionally; admin rebooting — neither should drop the
+ * console rails).
+ *
+ * Sony's path (RE'd from orbis-12.02.elf, 2026-05-11)
+ * ---------------------------------------------------
+ * icc_power_shutdown_final (FUN_c8574860) builds a 0x800-byte buffer:
+ *
+ *   buf[1]      = 0x04         major = power
+ *   buf[2..3]   = 0x0004       minor = shutdown_final
+ *   buf[6..7]   = 0x0020       payload length = 32 bytes
+ *   buf[8..]    = zeros
+ *
+ * sends via icc_send_recv (FUN_c87e3050, sourced from
+ * freebsd/sys/dev/scesb/icc/icc.c per embedded debug strings), then
+ * issues a low-level MMIO sequence at the ICC BAR +0x1C8400 to actually
+ * drop the rails — see icc_lowlevel_power_off (FUN_c85b2660).
+ *
+ * Our first attempt sends only the mailbox command. On many EMC
+ * firmwares this is sufficient — the EMC drops rails when it
+ * processes shutdown_final. If hardware test shows the console doesn't
+ * actually power off after the ICC command, the follow-up adds the
+ * low-level MMIO writes. That requires exposing the ICC MMIO mapping
+ * from ps4-bpcie-icc.c; sketched in the research note at
+ * checkpoint/docs/research/orbis-kernel/2026-05-11-orbis-poweroff-discovered.md.
+ */
+
+#include <linux/init.h>
+#include <linux/module.h>
+#include <linux/reboot.h>
+#include <linux/delay.h>
+#include <linux/printk.h>
+#include <linux/notifier.h>
+
+#include "aeolia.h"
+#include "baikal.h"
+
+extern bool apcie_initialized;
+extern bool bpcie_initialized;
+
+static int ps4_reboot_notify(struct notifier_block *nb,
+			     unsigned long action, void *data)
+{
+	/* Sony's payload: 32 zero bytes, built on the stack so this is
+	 * runnable from any reboot context (no allocation). */
+	u8 zero_payload[0x20] = { 0 };
+	int ret;
+
+	/* Only act on poweroff. Halt and restart should NOT drop the
+	 * console rails — for restart we want Linux to reboot, for halt
+	 * we want to stay at standby intentionally. */
+	if (action != SYS_POWER_OFF)
+		return NOTIFY_DONE;
+
+	if (!apcie_initialized && !bpcie_initialized) {
+		pr_warn("ps4-power: no PS4 southbridge initialized; "
+			"falling through to default poweroff\n");
+		return NOTIFY_DONE;
+	}
+
+	pr_info("ps4-power: SYS_POWER_OFF — sending ICC shutdown_final "
+		"(cmd 04/0004) to drop console rails\n");
+
+	/* apcie_icc_cmd auto-routes to bpcie_icc_cmd when bpcie_initialized
+	 * (ps4-apcie-icc.c::apcie_icc_cmd), so this one call covers both
+	 * Aeolia/Belize (original PS4) and Baikal (PS4 CUH-15xx+).        */
+	ret = apcie_icc_cmd(0x04, 0x0004,
+			    zero_payload, sizeof(zero_payload),
+			    NULL, 0);
+	if (ret < 0) {
+		pr_err("ps4-power: ICC shutdown_final failed (%d); "
+		       "EMC will not drop rails\n", ret);
+		return NOTIFY_DONE;
+	}
+
+	pr_info("ps4-power: ICC accepted; waiting for EMC to cut rails\n");
+
+	/* If the EMC drops rails on receipt of the command, we never
+	 * reach the end of this delay — the CPU loses power mid-loop.
+	 * If we DO get past this, the ICC command alone wasn't enough
+	 * and the low-level MMIO sequence is needed (v72c+ followup,
+	 * see file header). Linux's regular shutdown path runs after
+	 * we return, so at minimum the system halts cleanly. */
+	mdelay(3000);
+
+	pr_warn("ps4-power: EMC did not cut power after ICC command — "
+		"low-level MMIO sequence (icc_bar +0x1C8400) is needed; "
+		"see ps4-power.c header\n");
+
+	return NOTIFY_DONE;
+}
+
+static struct notifier_block ps4_reboot_nb = {
+	.notifier_call = ps4_reboot_notify,
+	/* Run last in the SYS_POWER_OFF notifier chain so other quiesce
+	 * actions complete first (e.g. filesystem sync via subsystem
+	 * notifiers running with higher priority). INT_MIN is the
+	 * standard "do this absolutely last" value. */
+	.priority = INT_MIN,
+};
+
+static int __init ps4_power_init(void)
+{
+	if (!apcie_initialized && !bpcie_initialized) {
+		/* Not on PS4 hardware (or southbridge driver not yet
+		 * initialized — late_initcall should prevent the latter). */
+		return -ENODEV;
+	}
+
+	register_reboot_notifier(&ps4_reboot_nb);
+	pr_info("ps4-power: reboot_notifier installed — ICC cmd 04/0004 "
+		"on SYS_POWER_OFF\n");
+	return 0;
+}
+
+/* late_initcall so apcie/bpcie (device_initcall) have already finished
+ * their probe and set *_initialized. */
+late_initcall(ps4_power_init);
+
+MODULE_DESCRIPTION("PS4 console power-off via ICC mailbox (reboot_notifier)");
+MODULE_LICENSE("GPL");

From: PS4 Linux Baikal Port <noreply@ps4-linux>
Subject: [PATCH] drivers/ps4: bpcie MSI debug logging (DIAGNOSTIC, REVERT)

Add diagnostic printk()s to figure out why xHCI Command Aborted
persists even with the shared-vector demux bypass:

1. bpcie_assign_irqs entry+exit — log devfn, requested nvec, returned
   nvec, dev->irq.

2. bpcie_msi_init — log every child virq the kernel creates in the
   bpcie MSI domain, with virq number and hwirq.  Tells us how many
   vectors actually exist for the demuxer to dispatch to.

3. bpcie_msi_write_msg — log addr_hi/addr_lo/data each time the kernel
   programs an MSI message.  Then read back from the device's MSI
   capability and compare; print MATCH/MISMATCH.  If the readback
   diverges, the device's PCI config isn't accepting the writes.

4. bpcie_handle_edge_irq entry — rate-limited pr_info every time the
   parent IRQ flow handler fires.  If we see writes from #3 but no
   logs from #4, the MSI never arrives — pointing at an APIC routing
   issue or the device not actually firing.

The two suspicious "Spurious interrupt (vector 0xef) on CPU#0. Acked"
events on boot #11 suggest MSI vector misroute.  This patch should
give us ground truth.

REVERT BEFORE LANDING ANY USB-WORKING KERNEL — this is purely
diagnostic and will spam dmesg.

Signed-off-by: Meerzulee <17146298+meerzulee@users.noreply.github.com>
---
--- a/drivers/ps4/ps4-bpcie.c
+++ b/drivers/ps4/ps4-bpcie.c
@@ -56,10 +56,28 @@
 		return;
 	}
 
-	dev_dbg(data->common->msi_desc->dev, "bpcie_msi_write_msg(%08x, %08x) mask=0x%x irq=%d hwirq=0x%lx %p\n",
-	       msg->address_lo, msg->data, data->mask, data->irq, data->hwirq, sc);
+	dev_info(data->common->msi_desc->dev,
+		 "bpcie_msi_write_msg: WRITE addr_hi=%08x addr_lo=%08x data=%08x mask=0x%x irq=%d hwirq=0x%lx\n",
+		 msg->address_hi, msg->address_lo, msg->data, data->mask,
+		 data->irq, data->hwirq);
 
 	pci_msi_domain_write_msg(data, msg);
+
+	/* Read back from the device's MSI capability to verify the write
+	 * stuck.  If the readback differs we know the device's PCI config
+	 * isn't accepting writes (or the BAR mapping is wrong). */
+	{
+		struct msi_msg readback = {0};
+		struct pci_dev *pdev = msi_desc_to_pci_dev(data->common->msi_desc);
+		if (pdev) {
+			__pci_read_msi_msg(data->common->msi_desc, &readback);
+			dev_info(&pdev->dev,
+				 "bpcie_msi_write_msg: READBACK addr_hi=%08x addr_lo=%08x data=%08x %s\n",
+				 readback.address_hi, readback.address_lo, readback.data,
+				 (readback.address_lo == msg->address_lo &&
+				  readback.data == msg->data) ? "(MATCH)" : "(MISMATCH!)");
+		}
+	}
 }
 
 static void bpcie_msi_unmask(struct irq_data *data)
@@ -215,6 +233,10 @@
 	u32 func = (desc->irq_data.hwirq >> 5) & 7;
 	u32 initial_hwirq = desc->irq_data.hwirq & ~0x1fLL;
 
+	pr_info_ratelimited("bpcie_handle_edge_irq: irq=%d hwirq=0x%lx func=%u shared=%d\n",
+			    desc->irq_data.irq, desc->irq_data.hwirq, func,
+			    (desc->irq_data.hwirq & 0x1f) == 0x1f);
+
 	/*
 	 * Shared-vector mode: when bpcie_msi_domain_set_desc has OR'd 0x1F
 	 * into the hwirq (the no-IOMMU-IR fallback that allocates one MSI
@@ -287,7 +309,7 @@
 			 irq_hw_number_t hwirq, msi_alloc_info_t *arg)
 {
 	struct irq_data *data;
-	pr_devel("bpcie_msi_init(%p, %p, %d, 0x%lx, %p)\n", domain, info, virq, hwirq, arg);
+	pr_info("bpcie_msi_init: virq=%d hwirq=0x%lx domain=%p info=%p\n", virq, hwirq, domain, info);
 
 	data = irq_domain_get_irq_data(domain, virq);
 	irq_domain_set_info(domain, virq, hwirq, info->chip, info->chip_data,
@@ -426,7 +448,7 @@
 		goto fail;
 	}
 
-	dev_dbg(&dev->dev, "bpcie_assign_irqs(%d)\n", nvec);
+	dev_info(&dev->dev, "bpcie_assign_irqs: requested nvec=%d msi_enabled=%d\n", nvec, dev->msi_enabled);
 
 #ifndef QEMU_HACK_NO_IOMMU
 	if (!(bpcie_msi_domain_info.flags & MSI_FLAG_MULTI_PCI_MSI)) {
@@ -440,7 +462,7 @@
 		ret = pci_alloc_irq_vectors(dev, 1, nvec, PCI_IRQ_MSI);
 
 fail:
-	dev_dbg(&dev->dev, "bpcie_assign_irqs returning %d\n", ret);
+	dev_info(&dev->dev, "bpcie_assign_irqs returning %d (dev->irq=%d)\n", ret, dev->irq);
 	if (sc_dev)
 		pci_dev_put(sc_dev);
 	return ret;

+++ b/drivers/gpu/drm/amd/amdgpu/uvd_v4_2.c
@@ -23,6 +23,8 @@

 #include <linux/firmware.h>

+#include <drm/ttm/ttm_tt.h>
+
 #include "amdgpu.h"
 #include "amdgpu_uvd.h"
 #include "cikd.h"
@@ -447,13 +449,106 @@
  * Full per-register rationale + Ghidra rename map:
  *   checkpoint/docs/research/orbis-kernel/2026-05-11-uvd-vcpu-start-found.md

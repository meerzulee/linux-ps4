+/*
+ * PS4 UVD VCPU clock divider hint. Sony's uvd_vcpu_start_baikal reads
+ * this from per-chip-info struct field +0x134 (decompile + 3-way variant
+ * diff confirmed: annotated as "clock divider hint, low 4 bits").
+ *
+ * Default 4 backed by two independent signals:
+ *   1. Sony source annotation in plate-comment on uvd_vcpu_start_gladius
+ *   2. Empirical FB_DIV=0x04 read from CG_SPLL_FUNC_CNTL via the mainline
+ *      mmGCK_SMC_IND path during session-4 SBL bring-up work
+ *
+ * Override via amdgpu.ps4_uvd_clkdiv=N if hardware disagrees.
+ * Range 0-15; values >15 are masked to nibble.
+ */
+uint ps4_uvd_clkdiv = 4;
+module_param_named(ps4_uvd_clkdiv, ps4_uvd_clkdiv, uint, 0444);
+MODULE_PARM_DESC(ps4_uvd_clkdiv, "PS4 UVD VCPU clock divider (0-15, default 4)");

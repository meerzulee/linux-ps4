+/* v0064 debugfs: ps4_uvd_status — read → key UVD regs + R1/R2/R3 bytes. */
+static ssize_t ps4_uvd_status_read(struct file *file, char __user *buf,
+				   size_t cnt, loff_t *ppos)
+{
+	char tmp[1024];
+	int len;
+	struct amdgpu_device *adev = ps4_uvd_dbgfs_adev;
+	u8 *m = (u8 *)uvd_fw_mirror_cpu_ptr;
+	u64 r1_lo = 0, r1_hi = 0, r2_lo = 0, r2_hi = 0, r3_lo = 0, r3_hi = 0;
+
+	if (!adev)
+		return -ENODEV;
+
+	if (m) {
+		r1_lo = *(u64 *)(m + 0x000000);
+		r1_hi = *(u64 *)(m + 0x000008);
+		r2_lo = *(u64 *)(m + 0x1E0000);
+		r2_hi = *(u64 *)(m + 0x1E0008);
+		r3_lo = *(u64 *)(m + 0x304000);
+		r3_hi = *(u64 *)(m + 0x304008);
+	}
+
+	len = snprintf(tmp, sizeof(tmp),
+		"PS4 UVD live status\n"
+		"==== UVD regs ====\n"
+		"  STATUS  (0x3daf) = 0x%08x   (bit 1=ready, bit 2=busy)\n"
+		"  0x3d67           = 0x%08x   (LMI VCPU sync)\n"
+		"  0x3d40           = 0x%08x   (LMI_CTRL2)\n"
+		"  0x3d98           = 0x%08x   (VCPU_CNTL)\n"
+		"  0x3da0 SOFT_RST  = 0x%08x\n"
+		"  0x3da9 DMA       = 0x%08x\n"
+		"  0x3dab sync      = 0x%08x\n"
+		"  RB_RPTR          = 0x%08x\n"
+		"  RB_WPTR          = 0x%08x\n"
+		"  LMI_VBASE_HI/LO  = 0x%08x / 0x%08x\n"
+		"  LMI_ADDR_EXT     = 0x%08x\n"
+		"  LMI_EXT40_ADDR   = 0x%08x\n"
+		"==== BO contents (first 16 bytes) ====\n"
+		"  R1 firmware @+0x000000 = %016llx %016llx\n"
+		"  R2 heap     @+0x1E0000 = %016llx %016llx\n"
+		"  R3 msgq     @+0x304000 = %016llx %016llx\n"
+		"\n",
+		RREG32(mmUVD_STATUS), RREG32(0x3d67), RREG32(0x3d40),
+		RREG32(0x3d98), RREG32(0x3da0), RREG32(0x3da9),
+		RREG32(0x3dab), RREG32(mmUVD_RBC_RB_RPTR),
+		RREG32(mmUVD_RBC_RB_WPTR),
+		RREG32(0x3c68), RREG32(0x3c69),
+		RREG32(mmUVD_LMI_ADDR_EXT), RREG32(mmUVD_LMI_EXT40_ADDR),
+		r1_lo, r1_hi, r2_lo, r2_hi, r3_lo, r3_hi);
+
+	return simple_read_from_buffer(buf, cnt, ppos, tmp, len);
+}
+static const struct file_operations ps4_uvd_status_fops = {
+	.owner = THIS_MODULE,
+	.read = ps4_uvd_status_read,
+};

+static void ps4_uvd_debugfs_register(struct amdgpu_device *adev)
+{
+	struct dentry *root;
+
+	if (!adev->ddev.primary)
+		return;
+	root = adev->ddev.primary->debugfs_root;
+	if (!root)
+		return;
+	if (ps4_uvd_debugfs_dir)	/* already registered */
+		return;
+	ps4_uvd_dbgfs_adev = adev;
+	debugfs_create_file("ps4_uvd_retry",  0200, root, NULL, &ps4_uvd_retry_fops);
+	debugfs_create_file("ps4_uvd_status", 0444, root, NULL, &ps4_uvd_status_fops);
+	pr_info("ps4 uvd: debugfs hooks registered: ps4_uvd_retry, ps4_uvd_status\n");

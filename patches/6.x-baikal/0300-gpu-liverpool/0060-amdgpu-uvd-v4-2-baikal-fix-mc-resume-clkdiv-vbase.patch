+/* v0064 debugfs: ps4_uvd_retry — write anything → re-run start_liverpool. */
+static ssize_t ps4_uvd_retry_write(struct file *file, const char __user *buf,
+				   size_t cnt, loff_t *ppos)
+{
+	int r;

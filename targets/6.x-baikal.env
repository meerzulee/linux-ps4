# Target: PS4 Baikal on Linux 6.15.4
#
# Base = vanilla kernel.org v6.15.4. All Baikal-specific code arrives via
# patches/6.x-baikal/ — extracted from crashniels' ps4-linux-6.15.y-baikal
# (which has already done the 5.4 → 6.15 forward-port) and feeRnt's
# Baikal-specific xhci shutdown fix on top. See
# scripts/generate-6.x-patches.sh.
#
# This target is the "modern kernel" goal. Once it boots cleanly under
# UART we have parity with the 5.4 baseline (minus mt7668 — see
# patches/6.x-baikal/9000-todo/README.md).

TARGET_NAME="6.x-baikal"
BASE_REPO="https://github.com/gregkh/linux.git"
BASE_REF="v6.15.4"
BASE_DEPTH=1
CONFIG_FILE="config/6.x-baikal.config"
SERIES_FILE="patches/6.x-baikal/series"
PATCHES_DIR="patches/6.x-baikal"
# 6.15 builds cleanly with modern GCC; matches feeRnt's published config.
COMPILER="gcc"

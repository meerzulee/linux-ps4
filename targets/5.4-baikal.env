# Target: PS4 Baikal on Linux 5.4.247
#
# Base = vanilla kernel.org v5.4.247.
# All Baikal-specific code arrives via patches/5.4-baikal/ — extracted from
# feeRnt's ps4-linux-12xx 5.4.247-baikal-dfaus branch, see
# scripts/generate-5.4-patches.sh.
#
# This is the "known-working baseline" target — once it boots cleanly under
# UART we use it as ground truth for the 6.x forward-port.

TARGET_NAME="5.4-baikal"
BASE_REPO="https://github.com/gregkh/linux.git"
BASE_REF="v5.4.247"
BASE_DEPTH=1
CONFIG_FILE="config/5.4-baikal.config"
SERIES_FILE="patches/5.4-baikal/series"
PATCHES_DIR="patches/5.4-baikal"
# feeRnt's working config sets CONFIG_CC_IS_CLANG=y / CONFIG_LD_IS_LLD=y
# (Clang 21.x), so we mirror that. GCC 13+ will not compile 5.4 cleanly.
COMPILER="clang"

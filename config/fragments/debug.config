# Debug Configuration Fragment
# Enable these options for kernel debugging
#
# WARNING: These options increase kernel size and reduce performance
# Only enable during development/debugging

# Kernel debugging
CONFIG_DEBUG_KERNEL=y
CONFIG_DEBUG_INFO=y
CONFIG_DEBUG_INFO_DWARF_TOOLCHAIN_DEFAULT=y

# Printk / console
CONFIG_PRINTK=y
CONFIG_PRINTK_TIME=y
CONFIG_CONSOLE_LOGLEVEL_DEFAULT=7
CONFIG_MESSAGE_LOGLEVEL_DEFAULT=4

# Early printk (useful for boot issues)
CONFIG_EARLY_PRINTK=y

# Magic SysRq (emergency debugging)
CONFIG_MAGIC_SYSRQ=y
CONFIG_MAGIC_SYSRQ_DEFAULT_ENABLE=0x1

# Dynamic debug
CONFIG_DYNAMIC_DEBUG=y
CONFIG_DYNAMIC_DEBUG_CORE=y

# Stack traces
CONFIG_STACKTRACE=y
CONFIG_FRAME_POINTER=y

# Memory debugging (optional, very slow)
# CONFIG_DEBUG_SLAB=y
# CONFIG_DEBUG_PAGEALLOC=y
# CONFIG_DEBUG_OBJECTS=y

# Lock debugging (optional)
# CONFIG_DEBUG_SPINLOCK=y
# CONFIG_DEBUG_MUTEXES=y
# CONFIG_DEBUG_LOCK_ALLOC=y

# DRM/GPU debugging
CONFIG_DRM_DEBUG_MODESET_LOCK=y

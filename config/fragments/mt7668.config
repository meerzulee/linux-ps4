# MediaTek MT7668 WiFi + Bluetooth Configuration
# For PS4 Slim/Pro with Baikal B1 southbridge
#
# Based on feeRnt's working 5.4.247-baikal config

# Enable MediaTek vendor
CONFIG_WLAN_VENDOR_MEDIATEK=y

# Wireless core
CONFIG_WIRELESS=y
CONFIG_CFG80211=m
CONFIG_CFG80211_WEXT=y
CONFIG_MAC80211=m

# MediaTek MT76 driver family (for MT7668)
CONFIG_MT76_CORE=m
CONFIG_MT76_LEDS=y
CONFIG_MT76_USB=m
CONFIG_MT76_SDIO=m
CONFIG_MT76x02_LIB=m
CONFIG_MT76x02_USB=m
CONFIG_MT7615_COMMON=m
CONFIG_MT7615E=m
CONFIG_MT7663_USB_SDIO_COMMON=m
CONFIG_MT7663S=m

# Additional MT76 drivers (optional, for other hardware)
# CONFIG_MT76x0_COMMON=m
# CONFIG_MT76x0U=m
# CONFIG_MT76x2_COMMON=m
# CONFIG_MT76x2E=m
# CONFIG_MT7603E=m

# Bluetooth
CONFIG_BT=y
CONFIG_BT_BREDR=y
CONFIG_BT_LE=y
CONFIG_BT_HCIUART=m
CONFIG_BT_HCIUART_H4=y
CONFIG_BT_MTKSDIO=m

# Firmware loading
CONFIG_FW_LOADER=y

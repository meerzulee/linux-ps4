# Build directories
src/
output/

# Reference repos (downloaded, not tracked)
tmp/

# Kernel build artifacts
*.o
*.ko
*.mod
*.mod.c
.tmp_versions/
modules.order
Module.symvers
vmlinux
vmlinux.o
# Don't ignore checkpoint/boot/bzImage — we deliberately commit the
# known-working prebuilt kernel there.
/bzImage
/output/**/bzImage

# Generated files
*.orig
*.rej

# Editor files
*.swp
*~
.vscode/
.idea/
*.kate-swp

# OS files
.DS_Store
Thumbs.db

# Local agent state and scratch
.claude/
debug/

# Reference vendor snapshots (local download cache, NOT tracked by default)
vendor/*
# ...but build dependencies under vendor/ ARE tracked (allow-listed):
!vendor/ps4-payload-sdk/
# Build artifacts inside tracked SDK dirs stay ignored:
vendor/ps4-payload-sdk/libPS4/build/
vendor/ps4-payload-sdk/libPS4/*.a
vendor/ps4-payload-sdk/libPS4/*.o

# Sony Orbis kernel dumps — research input, not redistributable.
# Reproduce by running tools/orbis-kernel-dumper/ on your own console.
checkpoint/docs/research/orbis-kernel/*.elf
checkpoint/docs/research/orbis-kernel/*.bin

# Orbis-side payload tools build outputs — sources + Makefiles
# under tools/orbis-*/ are tracked, build/ + .bin + .map are not.
tools/orbis-*/build/
tools/orbis-*/*.bin
tools/orbis-*/*.map
tools/orbis-*/*.o
